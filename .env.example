# Copy to .env and fill in. Required only for `--refresh` (re-pulling raw data).
# A clean clone reproduces every number from the committed data/raw cache
# WITHOUT this — the DB is only needed to refresh the cache.

# Supabase Postgres holding the `core.*` market-data schema (official NSE Nifty,
# FRED S&P 500, India VIX). Format:
#   postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require
DATABASE_URL=
